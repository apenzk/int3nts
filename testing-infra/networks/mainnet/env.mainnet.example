# Intent Framework Mainnet Deployment Keys
# Copy this file to .env.mainnet and fill in your values
# NEVER commit .env.mainnet to version control!
#
# WALLET IMPORT NOTES:
# - Movement keys (Nightly): Import via "Import Wallet" > paste private key (hex)
# - Base/HyperEVM keys (MetaMask): Import via "Import Account" > paste private key (hex with 0x)

# =============================================================================
# MOVEMENT MAINNET (Hub Chain) - Nightly Wallet Compatible
# =============================================================================

# Deployer - deploys the Move modules
# Generate with: aptos key generate --output-file movement-deployer.key
MOVEMENT_DEPLOYER_PRIVATE_KEY=
MOVEMENT_DEPLOYER_ADDR=

# Requester - creates intents (import into Nightly for browser access)
# Generate with: aptos key generate --output-file movement-requester.key
MOVEMENT_REQUESTER_PRIVATE_KEY=
MOVEMENT_REQUESTER_ADDR=

# Solver - fulfills intents (import into Nightly for browser access)
# Generate with: aptos key generate --output-file movement-solver.key
MOVEMENT_SOLVER_PRIVATE_KEY=
MOVEMENT_SOLVER_ADDR=

# Deployed intent module address (set automatically by deploy-to-movement.sh)
MOVEMENT_INTENT_MODULE_ADDR=

# Module admin private key (set automatically by deploy-to-movement.sh)
# Required by configure-movement.sh to set remote GMP endpoints
MOVEMENT_MODULE_PRIVATE_KEY=

# =============================================================================
# BASE MAINNET (Connected Chain) - MetaMask Compatible
# =============================================================================

# Deployer - deploys IntentEscrow contract
# Generate with: cast wallet new
BASE_DEPLOYER_PRIVATE_KEY=
BASE_DEPLOYER_ADDR=

# Requester - creates escrows (import into MetaMask for browser access)
# Generate with: cast wallet new
BASE_REQUESTER_PRIVATE_KEY=
BASE_REQUESTER_ADDR=

# Solver - claims escrows (import into MetaMask for browser access)
# Generate with: cast wallet new
BASE_SOLVER_EVM_PRIVATE_KEY=
BASE_SOLVER_ADDR=

# Deployed contract addresses (set automatically by deploy-to-base.sh)
BASE_GMP_ENDPOINT_ADDR=
BASE_INFLOW_ESCROW_ADDR=
BASE_OUTFLOW_VALIDATOR_ADDR=
BASE_CHAIN_ID=8453

# =============================================================================
# HYPERLIQUID MAINNET (Connected Chain) - MetaMask Compatible
# =============================================================================

# Deployer - deploys IntentEscrow contract
# Generate with: cast wallet new
HYPERLIQUID_DEPLOYER_PRIVATE_KEY=
HYPERLIQUID_DEPLOYER_ADDR=

# Requester - creates escrows (import into MetaMask for browser access)
# Generate with: cast wallet new
HYPERLIQUID_REQUESTER_PRIVATE_KEY=
HYPERLIQUID_REQUESTER_ADDR=

# Solver - claims escrows (import into MetaMask for browser access)
# Generate with: cast wallet new
HYPERLIQUID_SOLVER_EVM_PRIVATE_KEY=
HYPERLIQUID_SOLVER_ADDR=

# Deployed contract addresses (set automatically by deploy-to-hyperliquid.sh)
HYPERLIQUID_GMP_ENDPOINT_ADDR=
HYPERLIQUID_INFLOW_ESCROW_ADDR=
HYPERLIQUID_OUTFLOW_VALIDATOR_ADDR=
HYPERLIQUID_CHAIN_ID=999


# =============================================================================
# INTEGRATED-GMP KEYS
# =============================================================================

# Ed25519 keypair for signing approvals (base64 encoded)
# Generate new keys: cd integrated-gmp && cargo run --bin generate_keys
INTEGRATED_GMP_PRIVATE_KEY=
INTEGRATED_GMP_PUBLIC_KEY=

# Relay addresses on each chain (derived from the Ed25519 key above)
# Derive from existing keys: cd integrated-gmp && INTEGRATED_GMP_CONFIG_PATH=config/integrated-gmp_mainnet.toml cargo run --bin get_relay_addresses
INTEGRATED_GMP_MVM_ADDR=
INTEGRATED_GMP_EVM_PUBKEY_HASH=


# =============================================================================
# OPTIONAL: RPC endpoints
# =============================================================================

# Base Mainnet RPC URL
BASE_RPC_URL=

# HyperEVM Mainnet RPC URL
HYPERLIQUID_RPC_URL=
